           negativeposting         TYPE c LENGTH 1,
         END OF ts_item.

  TYPES: BEGIN OF ts_data,
           filename     TYPE zfi_de_filename,
           id_doc       TYPE zfi_de_id_doc,
           companycode  TYPE bukrs,
           documentdate TYPE dats,
           postingdate  TYPE dats,
           documenttype TYPE blart,
           currency     TYPE waers,
           headertext   TYPE bktxt,
           referencedoc TYPE xblnr1,
           headerref1   TYPE zfi_de_xref1,
           to_item      TYPE TABLE OF ts_item WITH DEFAULT KEY,
         END OF ts_data.

  TYPES tt_data TYPE STANDARD TABLE OF ts_data WITH DEFAULT KEY.

  "============================================================
  " 3. KIỂU DỮ LIỆU HỖ TRỢ MAPPING (MAPPING HELPER TYPES)
  "============================================================
  TYPES: BEGIN OF ts_currency_amount_calc,
           currencyrole           TYPE c LENGTH 2,
           journalentryitemamount TYPE fins_vwcur12,
           currency               TYPE waers,
           exchangerate           TYPE zfi_de_kursf,
           taxbaseamount          TYPE fins_vwcur12,
         END OF ts_currency_amount_calc.

  TYPES tt_currency_amount_calc TYPE STANDARD TABLE OF ts_currency_amount_calc WITH DEFAULT KEY.

  TYPES: BEGIN OF ts_onetime_partner,
           name                        TYPE c LENGTH 40,
           onetimebusinesspartnername2 TYPE c LENGTH 40,
           onetimebusinesspartnername3 TYPE i_onetimeaccountsupplier-businesspartnername3,
           onetimebusinesspartnername4 TYPE i_onetimeaccountsupplier-businesspartnername4,
           cityname                    TYPE c LENGTH 40,
           country                     TYPE c LENGTH 3,
           vatliability                TYPE stceg,
           taxnumber1                  TYPE i_onetimeaccountsupplier-taxid1,
         END OF ts_onetime_partner.

  "============================================================
  " 4. KIỂU DỮ LIỆU TRẢ VỀ (RESPONSE / RESULT TYPES)
  "============================================================
  TYPES: BEGIN OF ts_result,
           filename           TYPE zfi_de_filename,
           id_doc             TYPE zfi_de_id_doc,
           type               TYPE string,
           message            TYPE string,
           accountingdocument TYPE string,
         END OF ts_result.

  TYPES tt_results TYPE STANDARD TABLE OF ts_result WITH DEFAULT KEY.

  TYPES: BEGIN OF ts_response,
           error   TYPE string,
           results TYPE STANDARD TABLE OF ts_result WITH EMPTY KEY,
         END OF ts_response.

  "============================================================
  " 5. KIỂU DỮ LIỆU THAM CHIẾU CHỨNG TỪ (DOCUMENT REFERENCE TYPE)
  "============================================================
  TYPES: BEGIN OF ts_accounting_document,
           accountingdocument TYPE belnr_d,
           companycode        TYPE bukrs,
           fiscalyear         TYPE gjahr,
         END OF ts_accounting_document.

  TYPES tt_post_data TYPE TABLE FOR ACTION IMPORT i_journalentrytp~post.

  "============================================================
  " 6. KIỂU DỮ LIỆU HỖ TRỢ SOAP (SOAP HELPER TYPES)
  "============================================================
  TYPES: BEGIN OF ts_soap_response,
           accountingdocument TYPE belnr_d,
           companycode        TYPE bukrs,
           fiscalyear         TYPE gjahr,
           has_error          TYPE abap_bool,
           messages           TYPE tt_results,
         END OF ts_soap_response.

ENDINTERFACE.
