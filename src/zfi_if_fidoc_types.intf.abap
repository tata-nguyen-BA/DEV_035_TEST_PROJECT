           ref3                    TYPE c LENGTH 20,
           longtext                TYPE c LENGTH 100,
           unit                    TYPE meins,
           name1                   TYPE c LENGTH 40,
           name2                   TYPE c LENGTH 40,
           name3                   TYPE i_onetimeaccountsupplier-businesspartnername3,
           name4                   TYPE i_onetimeaccountsupplier-businesspartnername4,
           mst                     TYPE stcd1,
           city                    TYPE c LENGTH 40,
           country                 TYPE c LENGTH 3,
           namecus1                TYPE c LENGTH 40,
           namecus2                TYPE c LENGTH 40,
           namecus3                TYPE i_onetimeaccountsupplier-businesspartnername3,
           namecus4                TYPE i_onetimeaccountsupplier-businesspartnername4,
           mstcus                  TYPE i_onetimeaccountsupplier-taxid1,
           citycus                 TYPE c LENGTH 40,
           countrycus              TYPE c LENGTH 3,
           taxnumber1              TYPE i_onetimeaccountsupplier-taxid1,
           vatregno                TYPE stceg,
           quantity                TYPE menge_d,
           customer                TYPE i_customer-customer,
           supplier                TYPE lifnr,
           alternativepayee        TYPE lifnr,
           mstnccxuathd            TYPE c LENGTH 40,
           tennccxuathd            TYPE c LENGTH 80,
